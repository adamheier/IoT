<mxfile host="app.diagrams.net" type="device">
  <diagram name="Komponentendiagramm TMS (Blackbox)" id="component-tms">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="UML-Komponentendiagramm – TMS (Blackbox-Sicht)" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="640" height="30" as="geometry"/>
        </mxCell>

        <!-- System boundary -->
        <mxCell id="sys" value="«system» TMS – Transportmanagementsystem" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=13;spacingTop=8;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="200" y="80" width="720" height="700" as="geometry"/>
        </mxCell>

        <!-- Internal components -->
        <mxCell id="c_edi" value="«component»&#10;EDI-/Auftragsschnittstelle" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="250" y="140" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c_auftrag" value="«component»&#10;Auftragsverwaltung &amp; Disposition" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="580" y="140" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c_dok" value="«component»&#10;Dokumentenmanagement" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="250" y="300" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c_touren" value="«component»&#10;Touren- &amp; Routenoptimierung" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="580" y="300" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c_komm" value="«component»&#10;Kommissionierung &amp; Scanner-Anbindung" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="250" y="460" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c_mobile" value="«component»&#10;Mobile-Anbindung (Fahrer-App)" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="580" y="460" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="c_db" value="«component»&#10;Datenhaltung / TMS-Datenbank" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="415" y="630" width="230" height="80" as="geometry"/>
        </mxCell>

        <!-- External systems (outside boundary) -->
        <mxCell id="x_sped" value="«external»&#10;Spediteur-System (EDI)" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;dashed=1;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="150" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="x_gui" value="«external»&#10;Benutzer-GUI (Disponent/Lager)" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;dashed=1;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="980" y="150" width="180" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="x_scan" value="«external»&#10;Handscanner / Barcode-Terminal" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;dashed=1;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="470" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="x_mob" value="«external»&#10;Mobiles Fahrergerät" style="shape=module;jettyWidth=8;jettyHeight=4;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;dashed=1;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="980" y="470" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- Internal interfaces («use» dependencies) -->
        <mxCell id="i1" value="«use» IAuftragsempfang" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="c_auftrag" target="c_edi"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="i2" value="«use» IAuftrag" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="c_dok" target="c_auftrag"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="i3" value="«use» IAuftrag" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="c_touren" target="c_auftrag"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="i4" value="«use» IDokument" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="c_mobile" target="c_dok"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="i5" value="«use» IDatenzugriff" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="c_auftrag" target="c_db"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="i6" value="IDatenzugriff" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="c_dok" target="c_db"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="i7" value="IDatenzugriff" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="c_touren" target="c_db"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="i8" value="IDatenzugriff" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="c_komm" target="c_db"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- External interfaces (provided to environment) -->
        <mxCell id="x1" value="IEDI" style="endArrow=none;html=1;fontSize=10;" edge="1" parent="1" source="x_sped" target="c_edi"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="x2" value="IGUI" style="endArrow=none;html=1;fontSize=10;" edge="1" parent="1" source="x_gui" target="c_auftrag"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="x3" value="IScan" style="endArrow=none;html=1;fontSize=10;" edge="1" parent="1" source="x_scan" target="c_komm"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="x4" value="IMobile" style="endArrow=none;html=1;fontSize=10;" edge="1" parent="1" source="x_mob" target="c_mobile"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
