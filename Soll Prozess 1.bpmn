      <semantic:textAnnotation id="ID-d2da475f-61a3-11f1-422e-ea96ff8a7d92">
         <semantic:text>vollständig und unbeschädigt?</semantic:text>
      </semantic:textAnnotation>
      <semantic:textAnnotation id="ID-ccc77ba9-6368-11f1-422e-ea96ff8a7d92">
         <semantic:text>Prozesssprung zu Gruppe 3</semantic:text>
